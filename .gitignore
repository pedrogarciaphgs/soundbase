# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Uploaded files
public/uploads/artists/*
public/uploads/albums/*
public/uploads/songs/audio/*
public/uploads/songs/covers/*

# Keep upload folders
!public/uploads/artists/.gitkeep
!public/uploads/albums/.gitkeep
!public/uploads/songs/audio/.gitkeep
!public/uploads/songs/covers/.gitkeep